rectangle "Your computer = Windows host\n<size:10>[Deployment Node: Windows]</size>" <<UbuntuProForWSL.YourcomputerWindowshost>> as UbuntuProForWSL.YourcomputerWindowshost {
  rectangle "UP4W appx" <<group1>> {
    skinparam RectangleBorderColor<<group1>> #cccccc
    skinparam RectangleFontColor<<group1>> #cccccc
    skinparam RectangleBorderStyle<<group1>> dashed

    rectangle "==UP4W Windows GUI" <<UbuntuProForWSL.YourcomputerWindowshost.UP4WWindowsGUI_1>> as UbuntuProForWSL.YourcomputerWindowshost.UP4WWindowsGUI_1
    rectangle "==UP4W Windows Agent" <<UbuntuProForWSL.YourcomputerWindowshost.UP4WWindowsAgent_1>> as UbuntuProForWSL.YourcomputerWindowshost.UP4WWindowsAgent_1
  }

  rectangle "==Windows registry" <<UbuntuProForWSL.YourcomputerWindowshost.Windowsregistry_1>> as UbuntuProForWSL.YourcomputerWindowshost.Windowsregistry_1
  rectangle "WSL (VM)\n<size:10>[Deployment Node]</size>" <<UbuntuProForWSL.YourcomputerWindowshost.WSLVM>> as UbuntuProForWSL.YourcomputerWindowshost.WSLVM {
    rectangle "Ubuntu WSL instance (distro)\n<size:10>[Deployment Node: Ubuntu (Preview)]</size>" <<UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro>> as UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro {
      rectangle "==WSL Pro Service" <<UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro.WSLProService_1>> as UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro.WSLProService_1
