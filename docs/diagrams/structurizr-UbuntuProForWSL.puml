      rectangle "==Landscape Client" <<UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro.LandscapeClient_1>> as UbuntuProForWSL.YourcomputerWindowshost.WSLVM.UbuntuWSLinstancedistro.LandscapeClient_1
    }

  }

}

rectangle "Someone else's computer\n<size:10>[Deployment Node]</size>" <<UbuntuProForWSL.Someoneelsescomputer>> as UbuntuProForWSL.Someoneelsescomputer {
  rectangle "==Landscape Server" <<UbuntuProForWSL.Someoneelsescomputer.LandscapeServer_1>> as UbuntuProForWSL.Someoneelsescomputer.LandscapeServer_1
}

